<Window
    x:Class="ChatBot3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cybersecurity Awareness Bot - Part 3"
    Width="1200"
    Height="700"
    Background="#FF0D1117"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FF00B48A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF00896A" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TabHeader" TargetType="TabItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Background" Value="#FF161B22" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!--  LEFT PANEL: CHAT  -->
        <DockPanel Grid.Column="0" LastChildFill="True">
            <TextBox
                x:Name="AsciiArtBox"
                Height="120"
                Background="#FF161B22"
                BorderThickness="0"
                DockPanel.Dock="Top"
                FontFamily="Consolas"
                FontSize="9"
                Foreground="#FF00B48A"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                TextAlignment="Center"
                VerticalScrollBarVisibility="Hidden" />

            <Grid Margin="0,5,0,0" DockPanel.Dock="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="InputBox"
                    Grid.Column="0"
                    Padding="8"
                    Background="#FF161B22"
                    BorderBrush="#FF00B48A"
                    BorderThickness="1"
                    FontSize="13"
                    Foreground="White"
                    KeyDown="InputBox_KeyDown" />
                <Button
                    x:Name="SendButton"
                    Grid.Column="1"
                    Margin="5,0,0,0"
                    Click="SendButton_Click"
                    Content="Send"
                    Style="{StaticResource ModernButton}" />
                <Button
                    x:Name="ExitButton"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Background="#FFE53935"
                    Click="ExitButton_Click"
                    Content="Exit"
                    Style="{StaticResource ModernButton}" />
            </Grid>

            <TextBox
                x:Name="ChatBox"
                Margin="0,5,0,5"
                Background="#FF161B22"
                BorderBrush="#FF00B48A"
                BorderThickness="1"
                FontSize="13"
                Foreground="#FFE6EDF3"
                IsReadOnly="True"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
        </DockPanel>

        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            Background="#FF00B48A" />

        <!--  RIGHT PANEL: TABS  -->
        <TabControl
            Grid.Column="2"
            Background="#FF0D1117"
            BorderBrush="#FF00B48A"
            BorderThickness="1">

            <!--  TAB 1: TASK ASSISTANT  -->
            <TabItem Header="📋 Task Assistant" Style="{StaticResource TabHeader}">
                <DockPanel Margin="5" Background="#FF161B22">
                    <TextBlock
                        Margin="5"
                        DockPanel.Dock="Top"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#FF00B48A"
                        Text="Cybersecurity Task Manager"
                        TextAlignment="Center" />

                    <Border
                        Margin="5"
                        Padding="10"
                        BorderBrush="#FF00B48A"
                        BorderThickness="1"
                        CornerRadius="5"
                        DockPanel.Dock="Top">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Quick Add Task" />
                            <TextBlock
                                FontSize="11"
                                Foreground="#FF8B949E"
                                Text="Title:" />
                            <TextBox
                                x:Name="TaskTitleBox"
                                Margin="0,2,0,5"
                                Padding="6"
                                Background="#FF0D1117"
                                BorderBrush="#FF00B48A"
                                BorderThickness="1"
                                Foreground="White" />
                            <TextBlock
                                FontSize="11"
                                Foreground="#FF8B949E"
                                Text="Description (optional):" />
                            <TextBox
                                x:Name="TaskDescBox"
                                Margin="0,2,0,5"
                                Padding="6"
                                Background="#FF0D1117"
                                BorderBrush="#FF00B48A"
                                BorderThickness="1"
                                Foreground="White" />
                            <StackPanel Margin="0,3" Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="Reminder (days): " />
                                <TextBox
                                    x:Name="TaskReminderBox"
                                    Width="60"
                                    Padding="5"
                                    Background="#FF0D1117"
                                    BorderBrush="#FF00B48A"
                                    BorderThickness="1"
                                    Foreground="White"
                                    Text="0" />
                                <Button
                                    Margin="10,0,5,0"
                                    Click="AddTaskButton_Click"
                                    Content="Add Task"
                                    Style="{StaticResource ModernButton}" />
                                <Button
                                    Background="#FF1F6FEB"
                                    Click="RefreshTasksButton_Click"
                                    Content="Refresh"
                                    Style="{StaticResource ModernButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock
                        Margin="5,5,5,3"
                        DockPanel.Dock="Top"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Your Tasks:" />

                    <ListBox
                        x:Name="TaskList"
                        Margin="5"
                        Background="#FF0D1117"
                        BorderBrush="#FF00B48A"
                        FontSize="12"
                        Foreground="White">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,2"
                                    Padding="4,6"
                                    BorderBrush="#FF21262D"
                                    BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock
                                            Foreground="#FFE6EDF3"
                                            Text="{Binding DisplayText}"
                                            TextWrapping="Wrap" />
                                        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                                            <Button
                                                Margin="0,0,5,0"
                                                Padding="6,2"
                                                Background="#FF2E7D32"
                                                BorderThickness="0"
                                                Click="CompleteTaskButton_Click"
                                                Content="Complete"
                                                Cursor="Hand"
                                                FontSize="10"
                                                Foreground="White"
                                                Tag="{Binding Id}" />
                                            <Button
                                                Padding="6,2"
                                                Background="#FFE53935"
                                                BorderThickness="0"
                                                Click="DeleteTaskButton_Click"
                                                Content="Delete"
                                                Cursor="Hand"
                                                FontSize="10"
                                                Foreground="White"
                                                Tag="{Binding Id}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <!--  TAB 2: QUIZ GAME  -->
            <TabItem Header="🎮 Quiz Game" Style="{StaticResource TabHeader}">
                <ScrollViewer Background="#FF161B22" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock
                            Margin="0,5,0,15"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#FF00B48A"
                            Text="Cybersecurity Quiz Challenge"
                            TextAlignment="Center" />

                        <StackPanel x:Name="QuizStartPanel" HorizontalAlignment="Center">
                            <TextBlock
                                Margin="10"
                                FontSize="14"
                                Foreground="White"
                                Text="Test your cybersecurity knowledge!"
                                TextAlignment="Center" />
                            <TextBlock
                                Margin="5"
                                FontSize="12"
                                Foreground="#FF8B949E"
                                Text="12 Questions  •  MCQ and True/False"
                                TextAlignment="Center" />
                            <Button
                                Margin="20,15"
                                Padding="30,12"
                                HorizontalAlignment="Center"
                                Click="StartQuizButton_Click"
                                Content="Start Quiz"
                                FontSize="15"
                                Style="{StaticResource ModernButton}" />
                        </StackPanel>

                        <StackPanel x:Name="QuizPanel" Visibility="Collapsed">
                            <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                <TextBlock
                                    x:Name="QuizProgress"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="White" />
                                <TextBlock
                                    x:Name="QuizScoreLabel"
                                    Margin="20,0,0,0"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#FF00B48A" />
                                <TextBlock
                                    x:Name="QuizQuestionType"
                                    Margin="20,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#FF8B949E" />
                            </StackPanel>

                            <Border
                                Margin="0,0,0,10"
                                Padding="15"
                                BorderBrush="#FF00B48A"
                                BorderThickness="1"
                                CornerRadius="5">
                                <TextBlock
                                    x:Name="QuizQuestionText"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    TextWrapping="Wrap" />
                            </Border>

                            <StackPanel x:Name="QuizOptionsPanel" Margin="0,0,0,10" />

                            <Border
                                x:Name="QuizFeedbackBorder"
                                Margin="0,0,0,10"
                                Padding="10"
                                BorderThickness="1"
                                CornerRadius="5"
                                Visibility="Collapsed">
                                <TextBlock
                                    x:Name="QuizFeedback"
                                    FontSize="13"
                                    TextWrapping="Wrap" />
                            </Border>

                            <Button
                                x:Name="QuizNextButton"
                                HorizontalAlignment="Right"
                                Click="QuizNextButton_Click"
                                Content="Next Question"
                                Style="{StaticResource ModernButton}"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel
                            x:Name="QuizResultsPanel"
                            HorizontalAlignment="Center"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="QuizResultScore"
                                Margin="10"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#FF00B48A"
                                TextAlignment="Center" />
                            <TextBlock
                                x:Name="QuizResultMessage"
                                Margin="10,0,10,15"
                                FontSize="15"
                                Foreground="White"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                            <Button
                                Margin="20"
                                Padding="20,10"
                                HorizontalAlignment="Center"
                                Click="StartQuizButton_Click"
                                Content="Play Again"
                                FontSize="14"
                                Style="{StaticResource ModernButton}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!--  TAB 3: ACTIVITY LOG  -->
            <TabItem Header="📊 Activity Log" Style="{StaticResource TabHeader}">
                <DockPanel Margin="5" Background="#FF161B22">
                    <TextBlock
                        Margin="5"
                        DockPanel.Dock="Top"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#FF00B48A"
                        Text="Activity Log"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="ActivityLogCount"
                        Margin="5,0,5,5"
                        DockPanel.Dock="Top"
                        FontSize="11"
                        Foreground="#FF8B949E"
                        TextAlignment="Center" />

                    <StackPanel
                        Margin="5"
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Bottom"
                        Orientation="Horizontal">
                        <Button
                            Margin="5"
                            Click="ShowMoreActivityButton_Click"
                            Content="Show More"
                            Style="{StaticResource ModernButton}" />
                        <Button
                            Margin="5"
                            Background="#FFE53935"
                            Click="ClearActivityButton_Click"
                            Content="Clear Log"
                            Style="{StaticResource ModernButton}" />
                    </StackPanel>

                    <ListBox
                        x:Name="ActivityLogList"
                        Margin="5"
                        Background="#FF0D1117"
                        BorderBrush="#FF00B48A"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="White">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="#FF8B949E" />
                                <Setter Property="Padding" Value="5,3" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    FontSize="12"
                                    Text="{Binding DisplayText}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>